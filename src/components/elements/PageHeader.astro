---
interface Props {
    title: string;
    number: string;
}
const { title, number } = Astro.props;
---

<div class="page-header">
  <span class="number">{number}</span>
  <span class="title">{title}</span>
  <div class="line"></div>
</div>

<style>
.page-header {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  width: 100%;
  margin-bottom: 3rem;
}
.number {
  color: #64ffda;
  font-weight: 600;
  font-family: 'Fira Code', monospace;
  white-space: nowrap;
  font-size: 1rem;
  opacity: 0.75;
}
.title {
  color: #e2e8f0;
  font-weight: 700;
  font-size: 1.6rem;
  letter-spacing: -0.02em;
  white-space: nowrap;
}
.line {
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, rgba(100,255,218,0.2), rgba(255,255,255,0.04));
}
</style>